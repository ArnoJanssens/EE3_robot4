  9419                           
  9420                           	psect	config
  9421                           
  9422                           ;Config register CONFIG1 @ 0x300000
  9423                           ;	External Oscillator Selection
  9424                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
  9425                           ;	Reset Oscillator Selection
  9426                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
  9427   300000                     	org	3145728
  9428   300000  8F                 	db	143
  9429                           
  9430                           ;Config register CONFIG2 @ 0x300001
  9431                           ;	Clock out Enable bit
  9432                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
  9433                           ;	PRLOCKED One-Way Set Enable bit
  9434                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
  9435                           ;	Clock Switch Enable bit
  9436                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
  9437                           ;	Fail-Safe Clock Monitor Enable bit
  9438                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
  9439   300001                     	org	3145729
  9440   300001  FF                 	db	255
  9441                           
  9442                           ;Config register CONFIG3 @ 0x300002
  9443                           ;	MCLR Enable bit
  9444                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
  9445                           ;	Power-up timer selection bits
  9446                           ;	PWRTS = PWRT_OFF, PWRT is disabled
  9447                           ;	Multi-vector enable bit
  9448                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
  9449                           ;	IVTLOCK bit One-way set enable bit
  9450                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
  9451                           ;	Low Power BOR Enable bit
  9452                           ;	LPBOREN = OFF, Low-Power BOR disabled
  9453                           ;	Brown-out Reset Enable bits
  9454                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
  9455   300002                     	org	3145730
  9456   300002  FF                 	db	255
  9457                           
  9458                           ;Config register CONFIG4 @ 0x300003
  9459                           ;	Brown-out Reset Voltage Selection bits
  9460                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
  9461                           ;	ZCD Disable bit
  9462                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
  9463                           ;	PPSLOCK bit One-Way Set Enable bit
  9464                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
  9465                           ;	Stack Full/Underflow Reset Enable bit
  9466                           ;	STVREN = ON, Stack full/underflow will cause Reset
  9467                           ;	Low Voltage Programming Enable bit
  9468                           ;	LVP = ON, Low voltage programming enabled. MCLR/VPP pin function is MCLR. MCLRE config
      +                          uration bit is ignored
  9469                           ;	Extended Instruction Set Enable bit
  9470                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
  9471   300003                     	org	3145731
  9472   300003  FF                 	db	255
  9473                           
  9474                           ;Config register CONFIG5 @ 0x300004
  9475                           ;	WDT Period selection bits
  9476                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
  9477                           ;	WDT operating mode
  9478                           ;	WDTE = OFF, WDT Disabled; SWDTEN is ignored
  9479   300004                     	org	3145732
  9480   300004  9F                 	db	159
  9481                           
  9482                           ;Config register CONFIG6 @ 0x300005
  9483                           ;	WDT Window Select bits
  9484                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
  9485                           ;	WDT input clock selector
  9486                           ;	WDTCCS = SC, Software Control
  9487   300005                     	org	3145733
  9488   300005  FF                 	db	255
  9489                           
  9490                           ;Config register CONFIG7 @ 0x300006
  9491                           ;	Boot Block Size selection bits
  9492                           ;	BBSIZE = BBSIZE_512, Boot Block size is 512 words
  9493                           ;	Boot Block enable bit
  9494                           ;	BBEN = OFF, Boot block disabled
  9495                           ;	Storage Area Flash enable bit
  9496                           ;	SAFEN = OFF, SAF disabled
  9497                           ;	Background Debugger
  9498                           ;	DEBUG = 0x1, unprogrammed default
  9499   300006                     	org	3145734
  9500   300006  FF                 	db	255
  9501                           
  9502                           ;Config register CONFIG8 @ 0x300007
  9503                           ;	Boot Block Write Protection bit
  9504                           ;	WRTB = OFF, Boot Block not Write protected
  9505                           ;	Configuration Register Write Protection bit
  9506                           ;	WRTC = OFF, Configuration registers not Write protected
  9507                           ;	Data EEPROM Write Protection bit
  9508                           ;	WRTD = OFF, Data EEPROM not Write protected
  9509                           ;	SAF Write protection bit
  9510                           ;	WRTSAF = OFF, SAF not Write Protected
  9511                           ;	Application Block write protection bit
  9512                           ;	WRTAPP = OFF, Application Block not write protected
  9513   300007                     	org	3145735
  9514   300007  FF                 	db	255
  9515                           
