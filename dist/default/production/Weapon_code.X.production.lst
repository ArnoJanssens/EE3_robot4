 14766                           
 14767                           ;Config register CONFIG1 @ 0x300000
 14768                           ;	External Oscillator Selection
 14769                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
 14770                           ;	Reset Oscillator Selection
 14771                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
 14772   300000                     	org	3145728
 14773   300000  8F                 	db	143
 14774                           
 14775                           ;Config register CONFIG2 @ 0x300001
 14776                           ;	Clock out Enable bit
 14777                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 14778                           ;	PRLOCKED One-Way Set Enable bit
 14779                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 14780                           ;	Clock Switch Enable bit
 14781                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 14782                           ;	Fail-Safe Clock Monitor Enable bit
 14783                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 14784   300001                     	org	3145729
 14785   300001  FF                 	db	255
 14786                           
 14787                           ;Config register CONFIG3 @ 0x300002
 14788                           ;	MCLR Enable bit
 14789                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 14790                           ;	Power-up timer selection bits
 14791                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 14792                           ;	Multi-vector enable bit
 14793                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 14794                           ;	IVTLOCK bit One-way set enable bit
 14795                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 14796                           ;	Low Power BOR Enable bit
 14797                           ;	LPBOREN = OFF, Low-Power BOR disabled
 14798                           ;	Brown-out Reset Enable bits
 14799                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 14800   300002                     	org	3145730
 14801   300002  FF                 	db	255
 14802                           
 14803                           ;Config register CONFIG4 @ 0x300003
 14804                           ;	Brown-out Reset Voltage Selection bits
