  8539                           
  8540                           ;Config register CONFIG1 @ 0x300000
  8541                           ;	External Oscillator Selection
  8542                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
  8543                           ;	Reset Oscillator Selection
  8544                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
  8545   300000                     	org	3145728
  8546   300000  8F                 	db	143
  8547                           
  8548                           ;Config register CONFIG2 @ 0x300001
  8549                           ;	Clock out Enable bit
  8550                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
  8551                           ;	PRLOCKED One-Way Set Enable bit
  8552                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
  8553                           ;	Clock Switch Enable bit
  8554                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
  8555                           ;	Fail-Safe Clock Monitor Enable bit
  8556                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
  8557   300001                     	org	3145729
  8558   300001  FF                 	db	255
  8559                           
  8560                           ;Config register CONFIG3 @ 0x300002
  8561                           ;	MCLR Enable bit
  8562                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
  8563                           ;	Power-up timer selection bits
  8564                           ;	PWRTS = PWRT_OFF, PWRT is disabled
  8565                           ;	Multi-vector enable bit
  8566                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
  8567                           ;	IVTLOCK bit One-way set enable bit
  8568                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
  8569                           ;	Low Power BOR Enable bit
  8570                           ;	LPBOREN = OFF, Low-Power BOR disabled
  8571                           ;	Brown-out Reset Enable bits
  8572                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
  8573   300002                     	org	3145730
  8574   300002  FF                 	db	255
  8575                           
  8576                           ;Config register CONFIG4 @ 0x300003
  8577                           ;	Brown-out Reset Voltage Selection bits
  8578                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
  8579                           ;	ZCD Disable bit
  8580                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
  8581                           ;	PPSLOCK bit One-Way Set Enable bit
  8582                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
  8583                           ;	Stack Full/Underflow Reset Enable bit
  8584                           ;	STVREN = ON, Stack full/underflow will cause Reset
  8585                           ;	Low Voltage Programming Enable bit
  8586                           ;	LVP = ON, Low voltage programming enabled. MCLR/VPP pin function is MCLR. MCLRE config
      +                          uration bit is ignored
  8587                           ;	Extended Instruction Set Enable bit
  8588                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
  8589   300003                     	org	3145731
  8590   300003  FF                 	db	255
  8591                           
  8592                           ;Config register CONFIG5 @ 0x300004
  8593                           ;	WDT Period selection bits
  8594                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
  8595                           ;	WDT operating mode
  8596                           ;	WDTE = OFF, WDT Disabled; SWDTEN is ignored
  8597   300004                     	org	3145732
  8598   300004  9F                 	db	159
  8599                           
  8600                           ;Config register CONFIG6 @ 0x300005
  8601                           ;	WDT Window Select bits
  8602                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
  8603                           ;	WDT input clock selector
  8604                           ;	WDTCCS = SC, Software Control
  8605   300005                     	org	3145733
  8606   300005  FF                 	db	255
  8607                           
  8608                           ;Config register CONFIG7 @ 0x300006
  8609                           ;	Boot Block Size selection bits
  8610                           ;	BBSIZE = BBSIZE_512, Boot Block size is 512 words
  8611                           ;	Boot Block enable bit
  8612                           ;	BBEN = OFF, Boot block disabled
  8613                           ;	Storage Area Flash enable bit
  8614                           ;	SAFEN = OFF, SAF disabled
  8615                           ;	Background Debugger
  8616                           ;	DEBUG = 0x1, unprogrammed default
  8617   300006                     	org	3145734
  8618   300006  FF                 	db	255
  8619                           
