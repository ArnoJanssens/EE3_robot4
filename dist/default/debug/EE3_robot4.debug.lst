 17811                           
 17812                           ;Config register CONFIG1 @ 0x300000
 17813                           ;	External Oscillator Selection
 17814                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
 17815                           ;	Reset Oscillator Selection
 17816                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
 17817   300000                     	org	3145728
 17818   300000  8F                 	db	143
 17819                           
 17820                           ;Config register CONFIG2 @ 0x300001
 17821                           ;	Clock out Enable bit
 17822                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 17823                           ;	PRLOCKED One-Way Set Enable bit
 17824                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 17825                           ;	Clock Switch Enable bit
 17826                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 17827                           ;	Fail-Safe Clock Monitor Enable bit
 17828                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 17829   300001                     	org	3145729
 17830   300001  FF                 	db	255
 17831                           
 17832                           ;Config register CONFIG3 @ 0x300002
 17833                           ;	MCLR Enable bit
 17834                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 17835                           ;	Power-up timer selection bits
 17836                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 17837                           ;	Multi-vector enable bit
 17838                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 17839                           ;	IVTLOCK bit One-way set enable bit
 17840                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 17841                           ;	Low Power BOR Enable bit
 17842                           ;	LPBOREN = OFF, Low-Power BOR disabled
 17843                           ;	Brown-out Reset Enable bits
 17844                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 17845   300002                     	org	3145730
 17846   300002  FF                 	db	255
 17847                           
 17848                           ;Config register CONFIG4 @ 0x300003
 17849                           ;	Brown-out Reset Voltage Selection bits
 17850                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
 17851                           ;	ZCD Disable bit
