 10210                           	psect	config
 10211                           
 10212                           ;Config register CONFIG1 @ 0x300000
 10213                           ;	External Oscillator Selection
 10214                           ;	FEXTOSC = ECH, EC (external clock) above 8 MHz
 10215                           ;	Reset Oscillator Selection
 10216                           ;	RSTOSC = HFINTOSC_64MHZ, HFINTOSC with HFFRQ = 64 MHz and CDIV = 1:1
 10217   300000                     	org	3145728
 10218   300000  8F                 	db	143
 10219                           
 10220                           ;Config register CONFIG2 @ 0x300001
 10221                           ;	Clock out Enable bit
 10222                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 10223                           ;	PRLOCKED One-Way Set Enable bit
 10224                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 10225                           ;	Clock Switch Enable bit
 10226                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 10227                           ;	Fail-Safe Clock Monitor Enable bit
 10228                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 10229   300001                     	org	3145729
 10230   300001  FF                 	db	255
 10231                           
 10232                           ;Config register CONFIG3 @ 0x300002
 10233                           ;	MCLR Enable bit
 10234                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 10235                           ;	Power-up timer selection bits
 10236                           ;	PWRTS = PWRT_OFF, PWRT is disabled
 10237                           ;	Multi-vector enable bit
 10238                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 10239                           ;	IVTLOCK bit One-way set enable bit
 10240                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 10241                           ;	Low Power BOR Enable bit
 10242                           ;	LPBOREN = OFF, Low-Power BOR disabled
 10243                           ;	Brown-out Reset Enable bits
 10244                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 10245   300002                     	org	3145730
 10246   300002  FF                 	db	255
 10247                           
 10248                           ;Config register CONFIG4 @ 0x300003
 10249                           ;	Brown-out Reset Voltage Selection bits
 10250                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
 10251                           ;	ZCD Disable bit
 10252                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
 10253                           ;	PPSLOCK bit One-Way Set Enable bit
 10254                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
 10255                           ;	Stack Full/Underflow Reset Enable bit
 10256                           ;	STVREN = ON, Stack full/underflow will cause Reset
 10257                           ;	Low Voltage Programming Enable bit
 10258                           ;	LVP = ON, Low voltage programming enabled. MCLR/VPP pin function is MCLR. MCLRE config
      +                          uration bit is ignored
 10259                           ;	Extended Instruction Set Enable bit
 10260                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
 10261   300003                     	org	3145731
 10262   300003  FF                 	db	255
 10263                           
 10264                           ;Config register CONFIG5 @ 0x300004
 10265                           ;	WDT Period selection bits
 10266                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
 10267                           ;	WDT operating mode
 10268                           ;	WDTE = OFF, WDT Disabled; SWDTEN is ignored
 10269   300004                     	org	3145732
 10270   300004  9F                 	db	159
 10271                           
 10272                           ;Config register CONFIG6 @ 0x300005
 10273                           ;	WDT Window Select bits
 10274                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
 10275                           ;	WDT input clock selector
 10276                           ;	WDTCCS = SC, Software Control
 10277   300005                     	org	3145733
 10278   300005  FF                 	db	255
 10279                           
 10280                           ;Config register CONFIG7 @ 0x300006
 10281                           ;	Boot Block Size selection bits
 10282                           ;	BBSIZE = BBSIZE_512, Boot Block size is 512 words
 10283                           ;	Boot Block enable bit
 10284                           ;	BBEN = OFF, Boot block disabled
 10285                           ;	Storage Area Flash enable bit
 10286                           ;	SAFEN = OFF, SAF disabled
 10287                           ;	Background Debugger
 10288                           ;	DEBUG = 0x1, unprogrammed default
 10289   300006                     	org	3145734
 10290   300006  FF                 	db	255
 10291                           
 10292                           ;Config register CONFIG8 @ 0x300007
 10293                           ;	Boot Block Write Protection bit
 10294                           ;	WRTB = OFF, Boot Block not Write protected
 10295                           ;	Configuration Register Write Protection bit
 10296                           ;	WRTC = OFF, Configuration registers not Write protected
 10297                           ;	Data EEPROM Write Protection bit
 10298                           ;	WRTD = OFF, Data EEPROM not Write protected
 10299                           ;	SAF Write protection bit
 10300                           ;	WRTSAF = OFF, SAF not Write Protected
 10301                           ;	Application Block write protection bit
 10302                           ;	WRTAPP = OFF, Application Block not write protected
 10303   300007                     	org	3145735
 10304   300007  FF                 	db	255
 10305                           
 10306                           ;Config register CONFIG10 @ 0x300009
 10307                           ;	PFM and Data EEPROM Code Protection bit
 10308                           ;	CP = OFF, PFM and Data EEPROM code protection disabled
 10309   300009                     	org	3145737
 10310   300009  FF                 	db	255
